
# Database (Neon/Postgres)
DATABASE_URL=postgres://user:password@host:port/neondb

# Authentication (Auth.js)
AUTH_SECRET= # Generate with: npx auth secret
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
Homepage=http://localhost:3000
Callback= http://localhost:3000/api/auth/callback/github


# Cryptomus
# Merchant ID + Payment API key are required for checkout and webhook verification.
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_PAYMENT_API_KEY=
CRYPTOMUS_API_BASE=https://api.cryptomus.com
# Optional: only needed if you later add payout flows.
CRYPTOMUS_PAYOUT_API_KEY=

# App Links
APP_DOWNLOAD_URL=https://github.com/Jalal-Nasser/PassGen/releases/download/v1.0.6/PassGen.Setup.1.0.6.exe

# Public
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=github.mdeploy.dev
